{
  "name": "inmetrics",
  "version": "1.0.0",
  "description": "Automacao teste Inmetrics",
  "license": "ISC",
  "author": "Luis Delgado",
  "type": "commonjs",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:allure": "cypress run & allure generate allure-results --clean -o allure-report & allure open allure-report",
    "cy:run:headed": "cypress run --headed",
    "cy:run:login": "cypress run --spec \"cypress/e2e/features/web/login.feature\"",
    "cy:run:cart": "cypress run --spec \"cypress/e2e/features/web/cart.feature\"",
    "cy:run:search": "cypress run --spec \"cypress/e2e/features/web/search.feature\"",
    "cy:run:trello": "cypress run --spec \"cypress/e2e/features/api/trello.feature\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "allure-commandline": "^2.43.0",
    "allure-cypress": "^3.10.2",
    "allure-js-commons": "^3.10.2",
    "cypress": "^15.18.1",
    "cypress-cucumber-preprocessor": "^4.3.1",
    "dotenv": "^17.4.2"
  },
  "cypress-cucumber-preprocessor": {
    "step_definitions": "cypress/e2e/steps"
  }
}
